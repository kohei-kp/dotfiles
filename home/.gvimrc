"set background=dark
"set transparency=10
"set lines=90 colums=150
"set showtabline=2
"-------------------
"基本的な設定
"-------------------
set showtabline=2
set transparency=3
set imdisable
"ツールバー非表示
set guioptions-=T
"ツールバー表示
"set guioptions+=T

colorscheme hybrid

set antialias
"set nobackup
"set visualvell t_vb=
set nowrapscan
set columns=100
set lines=48
set tabstop=4
set guifont=Ricty:h14

hi LineNr ctermbg=black guifg=#778899
